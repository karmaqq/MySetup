{
  "name": "mysetup",
  "version": "1.1.6",
  "description": "Profesyonel Envanter ve Kurulum Yönetim Sistemi",
  "author": "Karma <shbkarma@gmail.com>",
  "main": "js/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "*",
    "electron-builder": "*"
  },
  "build": {
    "appId": "com.mysetup.app",
    "productName": "MySetup",
    "artifactName": "MySetup.exe",
    "copyright": "Copyright © 2026 Karma",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "karmaqq",
        "repo": "MySetup",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true,
      "shortcutName": "MySetup"
    }
  }
}
