{
    "name":  "mysetup",
    "version":  "1.5.6",
    "description":  "Profesyonel Envanter ve Kurulum YГѓЖ’Г†вЂ™ГѓвЂ Гўв‚¬в„ўГѓЖ’Гўв‚¬ЕЎГѓвЂљГ‚В¶netim Sistemi",
    "author":  "Karma \u003cshbkarma@gmail.com\u003e",
    "main":  "main.js",
    "scripts":  {
                    "start":  "electron .",
                    "build":  "electron-builder"
                },
    "dependencies":  {
                         "electron-updater":  "^6.8.3"
                     },
    "devDependencies":  {
                            "electron":  "^33.0.0",
                            "electron-builder":  "^25.0.0",
                            "progress-estimator":  "^0.3.1"
                        },
    "build":  {
                  "appId":  "com.mysetup.app",
                  "productName":  "MySetup",
                  "artifactName":  "MySetup.exe",
                  "copyright":  "Copyright ГѓЖ’Г†вЂ™ГѓВўГўвЂљВ¬Г…ВЎГѓЖ’Гўв‚¬ЕЎГѓвЂљГ‚В© 2026 Karma",
                  "directories":  {
                                      "output":  "dist",
                                      "buildResources":  "build"
                                  },
                  "publish":  [
                                  {
                                      "provider":  "github",
                                      "owner":  "karmaqq",
                                      "repo":  "MySetup",
                                      "releaseType":  "release"
                                  }
                              ],
                  "win":  {
                              "target":  [
                                             "nsis"
                                         ],
                              "icon":  "assets/icon.ico",
                              "requestedExecutionLevel":  "asInvoker"
                          },
                  "nsis":  {
                               "oneClick":  false,
                               "allowToChangeInstallationDirectory":  true,
                               "perMachine":  false,
                               "createDesktopShortcut":  true,
                               "runAfterFinish":  true,
                               "installerIcon":  "assets/icon.ico",
                               "uninstallerIcon":  "assets/icon.ico",
                               "shortcutName":  "MySetup",
                               "allowElevation":  true,
                               "deleteAppDataOnUninstall":  false
                           }
              }
}
